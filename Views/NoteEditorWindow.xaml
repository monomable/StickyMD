<Window x:Class="StickyMD.Views.NoteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sticky Note Editor"
        Width="300"
        Height="240"
        MinWidth="280"
        MinHeight="220"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="FormatButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#15000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#25000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10"
            Background="#EFE6B5"
            BorderBrush="#D6CEA0"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.24" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
                <RowDefinition Height="40" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="#EDE08D"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontSize="20"
                        Content="+"
                        Click="NewButton_Click"
                        ToolTip="새 노트" />

                <Button Grid.Column="2"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE700;"
                        ToolTip="메뉴" />

                <Button Grid.Column="3"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        Content="&#xE711;"
                        Click="CloseButton_Click"
                        ToolTip="닫기" />
            </Grid>

            <TextBox x:Name="EditorTextBox"
                     Grid.Row="1"
                     Text="{Binding SelectedNote.Content, UpdateSourceTrigger=PropertyChanged}"
                     Margin="10,8,10,8"
                     BorderThickness="0"
                     Background="Transparent"
                     FontSize="28"
                     FontFamily="Segoe UI"
                     Foreground="#1E1E1E"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled" />

            <Border Grid.Row="2"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#3A000000"
                    Background="#ECE2B0">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                    <Button Style="{StaticResource FormatButtonStyle}"
                            FontWeight="Bold"
                            Content="a"
                            Click="BoldButton_Click"
                            ToolTip="Bold (**텍스트**)" />

                    <Button Style="{StaticResource FormatButtonStyle}"
                            FontStyle="Italic"
                            Content="a"
                            Click="ItalicButton_Click"
                            ToolTip="Italic (*텍스트*)" />

                    <Button Style="{StaticResource FormatButtonStyle}"
                            Click="UnderlineButton_Click"
                            ToolTip="Underline (&lt;u&gt;텍스트&lt;/u&gt;)">
                        <TextBlock Text="a" TextDecorations="Underline" />
                    </Button>

                    <Button Style="{StaticResource FormatButtonStyle}"
                            Click="StrikeButton_Click"
                            ToolTip="Strike (~~텍스트~~)">
                        <TextBlock Text="a" TextDecorations="Strikethrough" />
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
