<Window x:Class="StickyMD.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StickyMD.ViewModels"
        Title="Sticky Notes"
        Width="330"
        Height="540"
        MinWidth="300"
        MinHeight="420"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Closing="MainWindow_Closing"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="15" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#16000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#17000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#29000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" CornerRadius="10" Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#18000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewNoteCommand}" />
    </Window.InputBindings>

    <Border CornerRadius="12"
            Background="#F3F3F3"
            BorderBrush="#D7D7D7"
            BorderThickness="1"
            Padding="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.24" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource HeaderButtonStyle}"
                        Content="+"
                        FontSize="20"
                        Command="{Binding NewNoteCommand}"
                        ToolTip="&#xC0C8; &#xBA54;&#xBAA8; &#xB9CC;&#xB4E4;&#xAE30;" />

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="25"
                           Foreground="#3C3C3C"
                           Text="Sticky Notes" />

                <Button x:Name="SettingsButton"
                        Grid.Column="2"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Content="&#xE700;"
                        Click="SettingsButton_Click"
                        ToolTip="&#xC124;&#xC815;">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="SettingsMenu"
                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="Windows &#xC2DC;&#xC791; &#xC2DC; &#xC2E4;&#xD589;"
                                      IsCheckable="True"
                                      IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                            <Separator />
                            <MenuItem Header="&#xD504;&#xB85C;&#xADF8;&#xB7A8; &#xC885;&#xB8CC;"
                                      Command="{Binding ExitAppCommand}" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="12"
                        Content="&#xE711;"
                        Click="CloseBoardButton_Click"
                        ToolTip="&#xAD00;&#xB9AC;&#xCC3D; &#xCD5C;&#xC18C;&#xD654;" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,8">
                <Border CornerRadius="6" Background="#DEDEDE" />

                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="#7A7A7A"
                           Text="&#xE721;"
                           IsHitTestVisible="False" />

                <TextBox x:Name="SearchTextBox"
                         Margin="30,0,8,0"
                         VerticalContentAlignment="Center"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="14"
                         Foreground="#3E3E3E"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="32,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#8D8D8D"
                           FontSize="14"
                           Text="&#xAC80;&#xC0C9;..."
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchTextBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding FilteredNotes}"
                     SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     MouseDoubleClick="NoteList_MouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NoteViewModel}">
                        <Border Background="{Binding NoteColorBrush}"
                                CornerRadius="10"
                                BorderBrush="#22000000"
                                BorderThickness="1"
                                Padding="10,8,10,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="20"
                                            Height="20"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="11"
                                            Foreground="#5A5A5A"
                                            Content="&#xE722;"
                                            ToolTip="&#xBA54;&#xBAA8; &#xC5F4;&#xAE30;"
                                            Command="{Binding DataContext.OpenNoteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" />

                                    <TextBlock Grid.Column="2"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="#6B6B6B"
                                               Text="{Binding UpdatedTimeText}" />

                                    <Button Grid.Column="3"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="20"
                                            Height="20"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Foreground="#5A5A5A"
                                            Content="&#xE74D;"
                                            ToolTip="&#xBA54;&#xBAA8; &#xC0AD;&#xC81C;"
                                            Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" />
                                </Grid>

                                <FlowDocumentScrollViewer Grid.Row="1"
                                                          Margin="0,6,0,0"
                                                          Height="70"
                                                          Document="{Binding PreviewDocument}"
                                                          IsToolBarVisible="False"
                                                          IsHitTestVisible="False"
                                                          BorderThickness="0"
                                                          Background="Transparent"
                                                          VerticalScrollBarVisibility="Hidden"
                                                          HorizontalScrollBarVisibility="Disabled" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>