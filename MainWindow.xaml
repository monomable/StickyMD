<Window x:Class="StickyMD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:StickyMD.Utils"
        Title="Sticky Notes"
        Width="300"
        Height="430"
        MinWidth="280"
        MinHeight="360"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="14" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#14000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#24000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemRoot" CornerRadius="10" Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#1A000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12"
            Background="#F2F2F2"
            BorderBrush="#D9D9D9"
            BorderThickness="1"
            Padding="6">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="6" Opacity="0.22" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontSize="20"
                        Content="+"
                        Command="{Binding CreateNoteCommand}"
                        ToolTip="새 노트" />

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="18"
                           Foreground="#3E3E3E"
                           Text="Sticky Notes" />

                <Button Grid.Column="2"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="15"
                        Content="&#xE700;"
                        ToolTip="메뉴" />

                <Button Grid.Column="3"
                        Style="{StaticResource HeaderButtonStyle}"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="13"
                        Content="&#xE711;"
                        Command="{Binding CloseAppCommand}"
                        ToolTip="닫기" />
            </Grid>

            <Grid Grid.Row="1" Margin="0,6,0,8">
                <Border CornerRadius="6"
                        Background="#DEDEDE"
                        BorderThickness="0"
                        Padding="8,0,8,0" />

                <TextBox x:Name="SearchTextBox"
                         Margin="8,0,8,0"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         Foreground="#424242"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#7A7A7A"
                           FontFamily="Segoe MDL2 Assets"
                           Text="&#xE721;"
                           IsHitTestVisible="False" />

                <TextBlock Margin="30,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#8B8B8B"
                           FontSize="14"
                           Text="Search..."
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding FilteredNotes}"
                     SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10"
                                Background="{Binding CardBackground}"
                                BorderThickness="1"
                                BorderBrush="#22000000"
                                Padding="10,8,10,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               Foreground="#7A6B48"
                                               Text="◉" />

                                    <TextBlock Grid.Column="2"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="#7A7A7A"
                                               Text="{Binding UpdatedTimeText}" />

                                    <Button Grid.Column="3"
                                            Width="20"
                                            Height="20"
                                            Padding="0"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Cursor="Hand"
                                            ToolTip="노트 삭제"
                                            Content="&#xE74D;"
                                            Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}" />
                                </Grid>

                                <RichTextBox Grid.Row="1" Height="62"
                                             Margin="0,6,0,0"
                                             utils:RichTextBoxBinding.BoundDocument="{Binding PreviewDocument}"
                                             IsReadOnly="True"
                                             IsReadOnlyCaretVisible="False"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Focusable="False"
                                             IsDocumentEnabled="True"
                                             VerticalScrollBarVisibility="Hidden"
                                             HorizontalScrollBarVisibility="Disabled" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
